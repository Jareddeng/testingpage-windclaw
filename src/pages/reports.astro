---
import Layout from '../layouts/Layout.astro';
import fs from 'fs';
import path from 'path';

const reportsDir = '../content/docs';
let reports = [];
try {
  const files = fs.readdirSync(path.join(import.meta.dirname, reportsDir)).filter(f => f.endsWith('.md'));
  reports = files.map(f => {
    const content = fs.readFileSync(path.join(import.meta.dirname, reportsDir, f), 'utf-8');
    const match = content.match(/^title:\s*["'](.*?)["']/m);
    const dateMatch = content.match(/^\d{4}-\d{2}-\d{2}/);
    const excerptMatch = content.match(/^---\s*\n(.{0,200}?)\n---/s);
    return {
      filename: f,
      title: match ? match[1] : f.replace('.md',''),
      date: dateMatch ? dateMatch[0] : '未知日期',
      excerpt: excerptMatch ? excerptMatch[1].substring(0, 100).replace(/\n/g,' ') : '点击查看完整报告...'
    };
  });
  reports.sort((a, b) => b.date.localeCompare(a.date));
} catch(e) { /* reports dir may not exist yet */ }

export const prerender = true;
---

<Layout title="深度报告 · Storage Dashboard">

  {reports.length > 0 ? (
    <div class="sh">
      <div class="st">深度报告</div>
      <div class="ss">AI 驱动的存储产业分析报告 · 每日自动生成</div>
    </div>
  ) : (
    <div class="empty-state">
      <div class="icon">📝</div>
      <p style="font-size:16px;margin-bottom:8px;">暂无报告</p>
      <p style="font-size:13px;">每日报告将在此自动更新</p>
      <p style="font-size:12px;margin-top:8px;color:var(--muted)">运行以下命令添加报告：</p>
      <pre style="background:var(--card);padding:12px;border-radius:8px;margin-top:8px;font-size:12px;color:var(--cyan);">
echo '---
title: "标题"
date: 2026-06-18
---

报告正文...
' > src/content/docs/2026-06-18.md

git add . && git commit -m "add report" && git push</pre>
    </div>
  )}

  {reports.map(r => (
    <div class="report-list-item">
      <div class="report-list-title">{r.title}</div>
      <div class="report-list-date">{r.date}</div>
      <div class="report-list-excerpt">{r.excerpt}</div>
    </div>
  ))}

  {reports.length > 0 && (
    <style>
      .report-viewer{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:32px;margin-bottom:16px}
      .report-viewer .md-body{font-size:14px;line-height:1.8;color:var(--sub)}
      .report-viewer .md-body h1,.report-viewer .md-body h2,.report-viewer .md-body h3{color:var(--text);margin:20px 0 10px}
      .report-viewer .md-body h2{border-left:3px solid var(--blue);padding-left:12px}
      .report-viewer .md-body strong{color:var(--text);font-weight:600}
      .report-viewer .md-body .hl{color:var(--cyan);font-weight:600}
      .report-viewer .md-body p{margin-bottom:12px}
      .report-viewer .md-body table{width:100%;border-collapse:collapse;margin:16px 0;font-size:13px}
      .report-viewer .md-body th{background:rgba(255,255,255,.05);padding:10px 12px;text-align:left;color:var(--sub);font-weight:600;border-bottom:1px solid var(--border)}
      .report-viewer .md-body td{padding:8px 12px;border-bottom:1px solid rgba(255,255,255,.03);color:var(--sub)}
      .report-viewer .md-body code{background:rgba(255,255,255,.05);padding:2px 6px;border-radius:4px;font-size:12px}
    </style>
  )}

</Layout>

<script>
// Simple markdown-to-HTML renderer (for embedded viewing)
document.querySelectorAll('.report-list-item').forEach(item => {
  item.addEventListener('click', () => {
    const fn = item.querySelector('.report-list-title')?.dataset?.fn;
    if (!fn) return;
    fetch('/reports/' + fn.replace('.md', '.html'))
      .then(r => r.text())
      .then(html => {
        const viewer = document.createElement('div');
        viewer.className = 'report-viewer';
        viewer.innerHTML = '<button onclick="this.parentElement.remove()" style="float:right;background:transparent;border:1px solid var(--border);color:var(--sub);padding:4px 12px;border-radius:6px;cursor:pointer;margin-bottom:12px">✕ 关闭</button>' + html;
        document.querySelector('.wrap').appendChild(viewer);
        viewer.scrollIntoView({behavior:'smooth'});
      })
      .catch(() => alert('报告渲染中，请稍后重试'));
  });
});
</script>
