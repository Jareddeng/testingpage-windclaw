---
import Layout from '../layouts/Layout.astro';
export const prerender = true;
---

<Layout title="DRAM 深度追踪 · Storage Dashboard">

  <div class="sh">
    <div class="st">DRAM 深度追踪</div>
    <div class="ss">DDR4/DDR5/HBM 价格、产能、供需全维度监控</div>
  </div>

  <div class="cgrid">
    <div class="cc">
      <div class="cch"><span class="ct">DRAM 现货 · DDR4 16Gb/8Gb & DDR5 16Gb</span><span class="cb">2025.01 - 2026.06</span></div>
      <div class="cbox" id="ch-dd"></div>
    </div>
    <div class="cc">
      <div class="cch"><span class="ct">DDR4 vs DDR5 价格柱状对比</span><span class="cb">产能转移 · 供应收缩</span></div>
      <div class="cbox" id="ch-di"></div>
    </div>
  </div>

  <div class="cgrid">
    <div class="cc">
      <div class="cch"><span class="ct">HBM 产能 vs 需求增长</span><span class="cb">2024-2027</span></div>
      <div class="cbox" id="ch-hbm"></div>
    </div>
    <div class="cc">
      <div class="cch"><span class="ct">三大原厂 DRAM 营收季度趋势</span><span class="cb">FY2024-FY2026</span></div>
      <div class="cbox" id="ch-rev"></div>
    </div>
  </div>

</Layout>

<script>
const M=['2025-01','2025-02','2025-03','2025-04','2025-05','2025-06','2025-07','2025-08','2025-09','2025-10','2025-11','2025-12','2026-01','2026-02','2026-03','2026-04','2026-05','2026-06'];
const S={backgroundColor:'transparent',textStyle:{color:'#94a3b8',fontSize:12},grid:{left:60,right:20,top:50,bottom:40},tooltip:{trigger:'axis',backgroundColor:'#111827',borderColor:'#1e293b',textStyle:{color:'#f1f5f9'}}};

function rc(id,opt){const e=document.getElementById(id);if(!e)return;const c=echarts.init(e,null,{renderer:'svg'});c.setOption(opt);window.addEventListener('resize',()=>c.resize());}
function lx(d){return{type:'category',data:d,splitLine:{show:false},axisLine:{lineStyle:{color:'#1e293b'}}}}
function vy(n){return{type:'value',name:n,splitLine:{lineStyle:{color:'#1e293b'}},axisLine:{show:false},axisLabel:{formatter:'${}'}}}
function barW(w){return{itemStyle:{borderRadius:w?[0,0,0,0]:0,barWidth:w||'30%'}}}

// DDR4/DDR5 detail
rc('ch-dd',{
  title:{text:'DRAM 现货价格走势',left:'center',textStyle:{color:'#f1f5f9',fontSize:14}},
  legend:{data:['DDR5 16Gb 4800','DDR4 16Gb 3200','DDR4 8Gb 3200'],top:25,textStyle:{color:'#94a3b8'}},
  xAxis:lx(M),yAxis:vy('USD/颗'),
  series:[
    {name:'DDR5 16Gb 4800',type:'line',data:[6.5,6.5,6.5,8.0,12.0,17.0,22.0,28.0,33.0,35.0,36.5,37.0,37.5,38.0,38.5,38.8],smooth:true,symbol:'circle',symbolSize:6,areaStyle:{opacity:0.1},lineStyle:{width:2}},
    {name:'DDR4 16Gb 3200',type:'line',data:[4.2,4.5,4.8,5.0,7.0,12.3,20.0,35.0,50.0,58.0,62.0,68.0,70.0,78.0,75.0,78.0],smooth:true,symbol:'circle',symbolSize:6,areaStyle:{opacity:0.1},lineStyle:{width:2}},
    {name:'DDR4 8Gb 3200',type:'line',data:[2.5,2.5,2.8,3.0,4.5,6.0,10.0,18.0,25.0,28.0,30.0,31.0,31.0,31.0,32.0,32.4],smooth:true,symbol:'circle',symbolSize:6,areaStyle:{opacity:0.1},lineStyle:{width:2}}
  ]
});

// DDR4 vs DDR5 bar
rc('ch-di',{
  title:{text:'DDR4/DDR5 价格对比 (Q2 2026)',left:'center',textStyle:{color:'#f1f5f9',fontSize:14}},
  legend:{data:['DDR4 16Gb','DDR5 16Gb'],top:25,textStyle:{color:'#94a3b8'}},
  xAxis:{type:'category',data:['Q2 2025','Q4 2025','Q1 2026','Q2 2026'],splitLine:{show:false},axisLine:{lineStyle:{color:'#1e293b'}}},
  yAxis:vy('USD/颗'),
  series:[
    {name:'DDR4 16Gb',type:'bar',data:[7,20,55,78],itemStyle:{color:'rgba(59,130,246,.6)',borderRadius:[4,4,0,0]},barWidth:'30%'},
    {name:'DDR5 16Gb',type:'bar',data:[17,28,36.5,38.8],itemStyle:{color:'rgba(6,182,212,.6)',borderRadius:[4,4,0,0]},barWidth:'30%'}
  ]
});

// HBM capacity vs demand
rc('ch-hbm',{
  title:{text:'HBM 产能 vs 需求 (百万 Gb)',left:'center',textStyle:{color:'#f1f5f9',fontSize:14}},
  legend:{data:['需求','供给（估算）'],top:25,textStyle:{color:'#94a3b8'}},
  xAxis:{type:'category',data:['2024','2025E','2026E','2027E'],splitLine:{show:false},axisLine:{lineStyle:{color:'#1e293b'}}},
  yAxis:vy('Gb'),
  series:[
    {name:'需求',type:'bar',data:[120,180,285,420],itemStyle:{color:'rgba(139,92,246,.7)',borderRadius:[4,4,0,0]},barWidth:'30%'},
    {name:'供给（估算）',type:'bar',data:[100,140,240,350],itemStyle:{color:'rgba(59,130,246,.5)',borderRadius:[4,4,0,0]},barWidth:'30%'}
  ],
  grid:{left:60,right:60,top:50,bottom:40}
});

// Revenue trend
const months=['2024Q1','2024Q2','2024Q3','2024Q4','2025Q1','2025Q2','2025Q3','2025Q4','2026Q1','2026Q2'];
rc('ch-rev',{
  title:{text:'三大原厂 DRAM 季度营收 (万亿韩元)',left:'center',textStyle:{color:'#f1f5f9',fontSize:14}},
  legend:{data:['SK 海力士','三星电子'],top:25,textStyle:{color:'#94a3b8'}},
  xAxis:{type:'category',data:months,splitLine:{show:false},axisLine:{lineStyle:{color:'#1e293b'}}},
  yAxis:vy('韩元'),
  series:[
    {name:'SK 海力士',type:'line',data:[210,222,244,328,380,420,526,560,526,600],smooth:true,symbol:'circle',symbolSize:6,lineStyle:{width:2.5}},
    {name:'三星电子',type:'line',data:[630,660,746,861,938,980,1050,1100,1339,1350],smooth:true,symbol:'circle',symbolSize:6,lineStyle:{width:2.5}}
  ]
});
</script>
