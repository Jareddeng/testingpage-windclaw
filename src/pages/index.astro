---
import Layout from '../layouts/Layout.astro';
---

<Layout title="总览 · Storage Dashboard">

  <div class="sh">
    <div class="st">存储三巨头 · 实时行情</div>
    <div class="ss">数据来源：Wind · 更新于 2026-06-18 15:21 CST</div>
  </div>

  <div class="tbar">
    <div class="tc hx">
      <div class="tch"><span class="tco">SK 海力士</span><span class="ttk">000660.KS</span></div>
      <div class="tp">₩2,698,000</div>
      <div class="tm">韩国交易所 · 韩元计价</div>
      <div class="tchg up">存储超级周期 · HBM 龙头</div>
      <div class="tpc">总市值：₩1,796.7 万亿</div>
    </div>
    <div class="tc sm">
      <div class="tch"><span class="tco">三星电子</span><span class="ttk">005930.KS</span></div>
      <div class="tp">₩3,675</div>
      <div class="tm">韩国交易所 · 韩元计价</div>
      <div class="tchg up">存储全能冠军 · 2D NAND 退出</div>
      <div class="tpc">总市值：$1,332B（伦敦）</div>
    </div>
    <div class="tc mu">
      <div class="tch"><span class="tco">美光科技</span><span class="ttk">MU.O</span></div>
      <div class="tp">$1,043.19</div>
      <div class="tm">纳斯达克 · 美元计价</div>
      <div class="tchg up">Q1 FY26 营收 $1,364 亿 · 创新高</div>
      <div class="tpc">总市值：$1,176B</div>
    </div>
  </div>

  <div class="kgrid">
    <div class="kc"><div class="kl">DRAM 合约价涨幅 (Q2)</div><div class="kv blue">+58~63%</div><div class="ku">环比 · TrendForce</div></div>
    <div class="kc"><div class="kl">NAND 合约价涨幅 (Q2)</div><div class="kv cyan">+70~75%</div><div class="ku">环比 · TrendForce</div></div>
    <div class="kc"><div class="kl">全球 HBM 位元消耗增长</div><div class="kv green">+92%</div><div class="ku">YoY · 285 亿 Gb</div></div>
    <div class="kc"><div class="kl">CSP 2026 Capex</div><div class="kv yellow">~$8,300B</div><div class="ku">+79% YoY</div></div>
  </div>

  <div class="cgrid">
    <div class="cc">
      <div class="cch"><span class="ct">DRAM 现货 · DDR4 vs DDR5</span><span class="cb">2025.01 - 2026.06</span></div>
      <div class="cbox" id="ch-do"></div>
    </div>
    <div class="cc">
      <div class="cch"><span class="ct">NAND 现货 · MLC 价格暴涨</span><span class="cb">2025.01 - 2026.06</span></div>
      <div class="cbox" id="ch-no"></div>
    </div>
  </div>

  <div class="cgrid f">
    <div class="cc">
      <div class="cch"><span class="ct">NAND 合约 · 多规格对比</span><span class="cb">2021.01 - 2026.06</span></div>
      <div class="cbox tall" id="ch-nc"></div>
    </div>
  </div>

</Layout>

<script>
const M=['2025-01','2025-02','2025-03','2025-04','2025-05','2025-06','2025-07','2025-08','2025-09','2025-10','2025-11','2025-12','2026-01','2026-02','2026-03','2026-04','2026-05','2026-06'];
const QS=['2021Q1','2021Q2','2021Q3','2021Q4','2022Q1','2022Q2','2022Q3','2022Q4','2023Q1','2023Q2','2023Q3','2023Q4','2024Q1','2024Q2','2024Q3','2024Q4','2025Q1','2025Q2','2025Q3','2025Q4','2026Q1','2026Q2'];
const nq128=[4.5,4.5,4.5,4.5,4.5,4.5,4.5,4.5,4.2,3.9,3.9,3.9,4.8,4.9,4.9,2.2,2.8,3.8,5.2,7.0,12.67,17.73];
const nq64=[3.0,3.0,3.0,3.0,3.0,3.0,3.0,3.0,2.6,2.5,2.5,2.6,3.4,3.4,3.4,2.0,2.3,3.0,4.8,6.0,9.5,13.2];
const nq32=[2.8,2.8,2.8,2.8,2.8,2.8,2.8,2.8,2.6,2.5,2.5,2.6,2.7,2.7,2.7,1.8,2.0,2.7,3.5,4.2,7.2,10.5];

const S={backgroundColor:'transparent',textStyle:{color:'#94a3b8',fontSize:12},grid:{left:60,right:20,top:50,bottom:40},tooltip:{trigger:'axis',backgroundColor:'#111827',borderColor:'#1e293b',textStyle:{color:'#f1f5f9'}}};

function renderChart(id, opt){
  const el=document.getElementById(id);
  if(!el)return;
  const c=echarts.init(el,null,{renderer:'svg'});
  c.setOption(opt);
  window.addEventListener('resize',()=>c.resize());
}

function lineX(d){return{type:'category',data:d,splitLine:{show:false},axisLine:{lineStyle:{color:'#1e293b'}}}}
function valY(n){return{type:'value',name:n,splitLine:{lineStyle:{color:'#1e293b'}},axisLine:{show:false},axisLabel:{formatter:'${}'}}}

renderChart('ch-do',{
  title:{text:'DRAM 现货价格',left:'center',textStyle:{color:'#f1f5f9',fontSize:14}},
  legend:{data:['DDR5 16Gb 4800','DDR4 16Gb 3200','DDR4 8Gb 3200'],top:25,textStyle:{color:'#94a3b8'}},
  xAxis:lineX(M),yAxis:valY('USD/颗'),
  series:[
    {name:'DDR5 16Gb 4800',type:'line',data:[6.5,6.5,6.5,8.0,12.0,17.0,22.0,28.0,33.0,35.0,36.5,37.0,37.5,38.0,38.5,38.8],smooth:true,symbol:'circle',symbolSize:6,areaStyle:{opacity:0.1},lineStyle:{width:2}},
    {name:'DDR4 16Gb 3200',type:'line',data:[4.2,4.5,4.8,5.0,7.0,12.3,20.0,35.0,50.0,58.0,62.0,68.0,70.0,78.0,75.0,78.0],smooth:true,symbol:'circle',symbolSize:6,areaStyle:{opacity:0.1},lineStyle:{width:2}},
    {name:'DDR4 8Gb 3200',type:'line',data:[2.5,2.5,2.8,3.0,4.5,6.0,10.0,18.0,25.0,28.0,30.0,31.0,31.0,31.0,32.0,32.4],smooth:true,symbol:'circle',symbolSize:6,areaStyle:{opacity:0.1},lineStyle:{width:2}}
  ]
});

renderChart('ch-no',{
  title:{text:'NAND 现货 · MLC 价格暴涨',left:'center',textStyle:{color:'#f1f5f9',fontSize:14}},
  legend:{data:['64Gb MLC','128Gb MLC'],top:25,textStyle:{color:'#94a3b8'}},
  xAxis:lineX(M),yAxis:valY('USD/颗'),
  series:[
    {name:'64Gb MLC',type:'line',data:[2.0,2.0,2.2,2.5,3.84,6.0,10.0,12.0,14.0,16.0,18.0,19.0,19.5,19.6,20.0,22.0,20,28],smooth:true,symbol:'circle',symbolSize:6,areaStyle:{opacity:0.15},lineStyle:{width:2.5}},
    {name:'128Gb MLC',type:'line',data:[3.0,3.2,3.5,4.0,6.4,8.0,12.0,14.0,16.0,18.0,20.0,21.0,22.0,23.0,24.0,25.0,26,28],smooth:true,symbol:'circle',symbolSize:6,areaStyle:{opacity:0.1},lineStyle:{width:2}}
  ]
});

renderChart('ch-nc',{
  title:{text:'NAND 合约价格 · 多规格 (2021-2026)',left:'center',textStyle:{color:'#f1f5f9',fontSize:14}},
  legend:{data:['128Gb MLC','64Gb MLC','32Gb MLC'],top:25,textStyle:{color:'#94a3b8'}},
  xAxis:{type:'category',data:QS,splitLine:{show:false},axisLine:{lineStyle:{color:'#1e293b'}}},
  yAxis:valY('USD/颗'),
  series:[
    {name:'128Gb MLC',type:'line',data:nq128,smooth:true,symbol:'circle',symbolSize:5,lineStyle:{width:2.5},areaStyle:{opacity:0.08}},
    {name:'64Gb MLC',type:'line',data:nq64,smooth:true,symbol:'circle',symbolSize:5,lineStyle:{width:2}},
    {name:'32Gb MLC',type:'line',data:nq32,smooth:true,symbol:'circle',symbolSize:5,lineStyle:{width:1.5,type:'dashed'}}
  ]
});
</script>
