---
interface Props {
  title: string;
  description?: string;
}
const { title, description = '存储产业链数据可视化看板' } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Ctext y='.9em' font-size='90'%3E🧠%3C/text%3E%3C/svg%3E">
  <meta name="description" content={description} />
  <title>{title}</title>
  <style is:global>
    *{margin:0;padding:0;box-sizing:border-box}
    :root{--bg:#0a0e17;--card:#111827;--card-hover:#1a2332;--border:#1e293b;--text:#f1f5f9;--sub:#94a3b8;--muted:#64748b;--blue:#3b82f6;--cyan:#06b6d4;--green:#10b981;--red:#ef4444;--yellow:#f59e0b;--purple:#8b5cf6}
    body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','PingFang SC','Microsoft YaHei',sans-serif;background:var(--bg);color:var(--text);line-height:1.6;min-height:100vh}
    a{color:inherit;text-decoration:none}
  </style>
  <style>
    .nav{background:rgba(17,24,39,.95);border-bottom:1px solid var(--border);padding:0 24px;height:56px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100;backdrop-filter:blur(12px)}
    .brand{display:flex;align-items:center;gap:10px;font-size:18px;font-weight:700}
    .brand-i{width:32px;height:32px;background:linear-gradient(135deg,var(--blue),var(--cyan));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px}
    .nav-links{display:flex;gap:4px}
    .nav-link{padding:8px 16px;border-radius:8px;color:var(--sub);font-size:14px;font-weight:500;transition:.2s;cursor:pointer}
    .nav-link:hover,.nav-link.active{color:var(--blue);background:rgba(59,130,246,.12)}
    .nav-right{display:flex;align-items:center;gap:12px;font-size:12px;color:var(--muted)}
    .badge{background:var(--green);color:#fff;padding:2px 8px;border-radius:10px;font-size:11px;font-weight:600}
    .wrap{max-width:1600px;margin:0 auto;padding:24px}
    .sh{margin-bottom:20px}.st{font-size:20px;font-weight:700}.ss{font-size:13px;color:var(--muted)}
    .tbar{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-bottom:24px}
    .tc{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;transition:.2s;position:relative;overflow:hidden}
    .tc:hover{background:var(--card);border-color:rgba(59,130,246,.3);transform:translateY(-2px);box-shadow:0 8px 32px rgba(0,0,0,.4)}
    .tc::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;border-radius:12px 12px 0 0}
    .tc.hx::before{background:linear-gradient(90deg,var(--blue),#60a5fa)}
    .tc.sm::before{background:linear-gradient(90deg,var(--cyan),#22d3ee)}
    .tc.mu::before{background:linear-gradient(90deg,var(--green),#34d399)}
    .tch{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
    .tco{font-size:16px;font-weight:700}.ttk{font-size:12px;color:var(--muted);background:rgba(255,255,255,.05);padding:2px 8px;border-radius:4px}
    .tp{font-size:28px;font-weight:800;margin-bottom:4px;font-variant-numeric:tabular-nums}
    .tm{font-size:12px;color:var(--muted);margin-bottom:12px}
    .tpc{font-size:12px;color:var(--muted);margin-top:8px}
    .tchg{display:inline-flex;align-items:center;padding:3px 8px;border-radius:6px;font-size:13px;font-weight:600}
    .tchg.up{color:var(--green);background:rgba(16,185,129,.1)}
    .kgrid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px}
    .kc{background:var(--card);border:1px solid var(--border);border-radius:10px;padding:16px;text-align:center}
    .kl{font-size:12px;color:var(--muted);margin-bottom:6px}
    .kv{font-size:22px;font-weight:800;font-variant-numeric:tabular-nums}
    .ku{font-size:12px;color:var(--muted);margin-top:2px}
    .kv.blue{color:var(--blue)}.kv.cyan{color:var(--cyan)}.kv.green{color:var(--green)}.kv.yellow{color:var(--yellow)}
    .cgrid{display:grid;grid-template-columns:repeat(2,1fr);gap:16px;margin-bottom:24px}
    .cgrid.f{grid-template-columns:1fr}
    .cc{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;transition:.2s}
    .cc:hover{border-color:rgba(59,130,246,.2);box-shadow:0 8px 32px rgba(0,0,0,.3)}
    .cch{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
    .ct{font-size:15px;font-weight:600}.cb{font-size:11px;color:var(--muted);background:rgba(255,255,255,.05);padding:2px 8px;border-radius:4px}
    .cbox{width:100%;height:360px}.cbox.tall{height:480px}
    .rc{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:32px;margin-bottom:16px}
    .rt{font-size:22px;font-weight:700;margin-bottom:8px;line-height:1.4}
    .rm{font-size:12px;color:var(--muted);margin-bottom:20px;display:flex;gap:16px;flex-wrap:wrap}
    .tag{background:rgba(59,130,246,.15);color:var(--blue);padding:2px 10px;border-radius:4px;font-size:12px}
    .rf{font-size:14px;line-height:1.8;color:var(--sub)}
    .rf p{margin-bottom:12px}
    .rf strong{color:var(--text);font-weight:600}
    .rf .hl{color:var(--cyan);font-weight:600}
    .rs{font-size:16px;font-weight:700;color:var(--text);margin:24px 0 12px;padding-left:12px;border-left:3px solid var(--blue)}
    .dtbl{width:100%;border-collapse:collapse;margin:16px 0;font-size:13px}
    .dtbl th{background:rgba(255,255,255,.05);padding:10px 12px;text-align:left;color:var(--sub);font-weight:600;border-bottom:1px solid var(--border)}
    .dtbl td{padding:8px 12px;border-bottom:1px solid rgba(255,255,255,.03);color:var(--sub)}
    .dtbl tr:hover td{background:rgba(255,255,255,.02)}
    .foot{text-align:center;padding:24px;font-size:12px;color:var(--muted);border-top:1px solid var(--border);margin-top:40px}
    .report-list-item{background:var(--card);border:1px solid var(--border);border-radius:12px;padding:20px;margin-bottom:12px;transition:.2s;cursor:pointer}
    .report-list-item:hover{border-color:rgba(59,130,246,.3);background:var(--card-hover)}
    .report-list-title{font-size:16px;font-weight:700;margin-bottom:4px}
    .report-list-date{font-size:12px;color:var(--muted);margin-bottom:8px}
    .report-list-excerpt{font-size:13px;color:var(--sub)}
    .empty-state{text-align:center;padding:60px 20px;color:var(--muted)}
    .empty-state .icon{font-size:48px;margin-bottom:16px}
    @media(max-width:1200px){.cgrid{grid-template-columns:1fr}.tbar{grid-template-columns:1fr}.kgrid{grid-template-columns:repeat(2,1fr)}}
    @media(max-width:768px){.nav-links{display:none}.kgrid{grid-template-columns:1fr 1fr}}
  </style>
</head>
<body>
  <nav class="nav">
    <div class="brand"><div class="brand-i">🧠</div><span>Storage Dashboard</span></div>
    <div class="nav-links">
      <a class="nav-link" href="/">总览</a>
      <a class="nav-link" href="/dram/">DRAM</a>
      <a class="nav-link" href="/nand/">NAND</a>
      <a class="nav-link" href="/reports/">深度报告</a>
    </div>
    <div class="nav-right"><span class="badge">LIVE</span><span>{new Date().toLocaleDateString('zh-CN',{year:'numeric',month:'2-digit',day:'2-digit'})} {new Date().toLocaleTimeString('zh-CN',{hour:'2-digit',minute:'2-digit',hour12:false})} CST</span></div>
  </nav>
  <div class="wrap">
    <main>
      <slot />
    </main>
  </div>
  <div class="foot">Storage Dashboard · 仅供参考，不构成投资建议 · 更新于 {new Date().toLocaleDateString('zh-CN')}</div>
  <script src="https://cdn.jsdelivr.net/npm/echarts@5.5.1/dist/echarts.min.js"></script>
  <slot name="scripts" />
</body>
</html>
